# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
else
  use_frameworks! :linkage => :static
end

target 'SERVICEHUB' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
        config.build_settings['ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        
        # Disable Explicit Modules (Xcode 16+) which breaks non-modular React-Core includes
        config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
        
        # Required for FirebaseAuth-Swift.h to be generated with static frameworks
        config.build_settings['DEFINES_MODULE'] = 'YES'
        
        # Ensure OTHER_CFLAGS is an array and suppresses non-modular errors
        cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        if cflags.is_a?(String)
          cflags = cflags.split(' ')
        end
        cflags << '-Wno-error=non-modular-include-in-framework-module'
        config.build_settings['OTHER_CFLAGS'] = cflags.uniq
        
        # Same for C++ flags
        cxxflags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
        if cxxflags.is_a?(String)
          cxxflags = cxxflags.split(' ')
        end
        cxxflags << '-Wno-error=non-modular-include-in-framework-module'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxxflags.uniq

        # Specific fix for Firebase modules to avoid "must be imported from module" errors
        if target.name.start_with?('RNFB')
          config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
          config.build_settings['DEFINES_MODULE'] = 'NO'
        end
      end
    end
  end
end
